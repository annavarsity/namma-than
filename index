# Audio player setup
try:
    from ffpyplayer.player import MediaPlayer
    FFPYPLAYER_AVAILABLE = True
except ImportError:
    FFPYPLAYER_AVAILABLE = False

# --- GLOBAL STATE FOR SYNC ---
sync_state = {
    "playing": False,
    "current_frame": 0,
    "exit": False,
    "command_queue": []
}

# --- NETWORK CONFIG ---
UDP_PORT = 54321
TCP_PORT = 54322

def get_local_ip():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        s.connect(('10.255.255.255', 1))
        ip = s.getsockname()[0]
    except Exception:
        ip = '127.0.0.1'
    finally:
        s.close()
    return ip

# --- HOST (SERVER) LOGIC ---
def host_network_thread(pin):
    host_ip = get_local_ip()
    
    # 1. Listen for UDP broadcast from Client
    udp_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    udp_sock.bind(('', UDP_PORT))
    print(f"[Network] Hosting on {host_ip}. Waiting for client with PIN: {pin}...")
    
    client_ip = None
    while not sync_state["exit"]:
        udp_sock.settimeout(1.0)
        try:
            data, addr = udp_sock.recvfrom(1024)
            msg = data.decode()
            if msg == f"DISCOVER:{pin}":
                print(f"[Network] Client found at {addr[0]}! Sending confirmation...")
                udp_sock.sendto(f"HOST_IP:{host_ip}".encode(), addr)
                client_ip = addr[0]
                break
        except socket.timeout:
            continue

    udp_sock.close()
    
    if sync_state["exit"] or not client_ip:
        return

    # 2. Setup TCP Server to send commands
    tcp_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    tcp_sock.bind(('', TCP_PORT))
    tcp_sock.listen(1)
    print("[Network] Waiting for TCP connection from client...")
    conn, addr = tcp_sock.accept()
    print(f"[Network] Connected and Synced with {addr[0]}!")

    # 3. Send commands from queue loop
    while not sync_state["exit"]:
        if sync_state["command_queue"]:
            cmd = sync_state["command_queue"].pop(0)
            try:
                conn.sendall(cmd.encode())
            except Exception as e:
                print(f"[Network Error] {e}")
                break
        time.sleep(0.01)
    
    conn.close()
    tcp_sock.close()

# --- CLIENT LOGIC ---
def client_network_thread(pin):
    # 1. Broadcast UDP to find Host
    udp_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    udp_sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    
    host_ip = None
    print(f"[Network] Searching for Host with PIN: {pin}...")
    
    while not sync_state["exit"] and not host_ip:
        udp_sock.sendto(f"DISCOVER:{pin}".encode(), ('<broadcast>', UDP_PORT))
        udp_sock.settimeout(2.0)
        try:
            data, addr = udp_sock.recvfrom(1024)
            msg = data.decode()
            if msg.startswith("HOST_IP:"):
                host_ip = msg.split(":")[1]
                print(f"[Network] Found Host at {host_ip}!")
        except socket.timeout:
            continue

    udp_sock.close()

    if sync_state["exit"] or not host_ip:
        return

    # 2. Connect via TCP to receive commands
    tcp_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        tcp_sock.connect((host_ip, TCP_PORT))
        print("[Network] Connected to Host! Waiting for sync commands...")
    except Exception as e:
        print(f"[Network Error] {e}")
        return

    # 3. Listen for commands loop
    while not sync_state["exit"]:
        try:
            data = tcp_sock.recv(1024)
            if not data:
                break
            
            commands = data.decode().split("|")
            for cmd in commands:
                if cmd == "PLAY":
                    sync_state["playing"] = True
                elif cmd == "PAUSE":
                    sync_state["playing"] = False
                elif cmd == "EXIT":
                    sync_state["exit"] = True
                elif cmd.startswith("SYNC:"):
                    frame = int(cmd.split(":")[1])
                    sync_state["current_frame"] = frame # Forces jump to frame
                    
        except Exception:
            break

    tcp_sock.close()

# --- VIDEO PLAYER LOGIC ---
def draw_buttons(frame, is_host):
    h, w = frame.shape[:2]
    # Button dimensions
    btn_w, btn_h = 120, 50
    margin = 20
    
    # Colors (BGR format)
    bg_color = (40, 40, 40)
    text_color = (255, 255, 255)
    
    # Play/Pause Button
    play_text = "PAUSE" if sync_state["playing"] else "PLAY"
    play_x1 = w // 2 - btn_w - margin
    play_x2 = play_x1 + btn_w
    play_y1 = h - btn_h - margin
    play_y2 = h - margin
    
    # Exit Button
    exit_x1 = w // 2 + margin
    exit_x2 = exit_x1 + btn_w
    exit_y1 = h - btn_h - margin
    exit_y2 = h - margin

    # Draw rectangles and text
    cv2.rectangle(frame, (play_x1, play_y1), (play_x2, play_y2), bg_color, -1)
    cv2.rectangle(frame, (exit_x1, exit_y1), (exit_x2, exit_y2), (40, 40, 200), -1)
    
    cv2.putText(frame, play_text, (play_x1 + 25, play_y1 + 35), cv2.FONT_HERSHEY_SIMPLEX, 0.8, text_color, 2)
    cv2.putText(frame, "EXIT", (exit_x1 + 35, exit_y1 + 35), cv2.FONT_HERSHEY_SIMPLEX, 0.8, text_color, 2)

    return [(play_x1, play_y1, play_x2, play_y2, "PLAY_PAUSE"), 
            (exit_x1, exit_y1, exit_x2, exit_y2, "EXIT")]

def handle_mouse(event, x, y, flags, param):
    buttons = param.get("buttons", [])
    is_host = param.get("is_host", False)

    if event == cv2.EVENT_LBUTTONDOWN:
        for (x1, y1, x2, y2, action) in buttons:
            if x1 <= x <= x2 and y1 <= y <= y2:
                if action == "PLAY_PAUSE":
                    if is_host: # Only host can control playback
                        new_state = not sync_state["playing"]
                        sync_state["playing"] = new_state
                        cmd = "PLAY|" if new_state else "PAUSE|"
                        sync_state["command_queue"].append(cmd)
                    else:
                        print("Only the HOST can control playback.")
                elif action == "EXIT":
                    sync_state["exit"] = True
                    if is_host:
                        sync_state["command_queue"].append("EXIT|")


def start_player(video_path, side, role, pin, play_audio):
    # Start Network Thread
    if role == "host":
        net_thread = threading.Thread(target=host_network_thread, args=(pin,))
    else:
        net_thread = threading.Thread(target=client_network_thread, args=(pin,))
    
    net_thread.daemon = True
    net_thread.start()

    # Load Video
    cap = cv2.VideoCapture(video_path)
    fps = cap.get(cv2.CAP_PROP_FPS)
    frame_delay = int(1000 / fps) if fps > 0 else 30

    # Load Audio
    player = MediaPlayer(video_path) if play_audio else None

    # Calculate Crops
    ret, frame = cap.read()
    orig_h, orig_w = frame.shape[:2]
    target_h = int(orig_w * (9 / 32))
    y_start = (orig_h - target_h) // 2
    y_end = y_start + target_h
    half_w = orig_w // 2

    # Setup Window
    window_name = "Ultrawide Sync Player"
    cv2.namedWindow(window_name, cv2.WINDOW_NORMAL)
    cv2.setWindowProperty(window_name, cv2.WND_PROP_FULLSCREEN, cv2.WINDOW_FULLSCREEN)

    # Sync variables
    last_sync_time = time.time()
    
    print("\n>>> Player Started! Waiting for network sync... <<<")

    while not sync_state["exit"]:
        # If client receives a sync command, jump to that frame
        if role == "client" and cap.get(cv2.CAP_PROP_POS_FRAMES) < sync_state["current_frame"] - 5:
             cap.set(cv2.CAP_PROP_POS_FRAMES, sync_state["current_frame"])
             if player:
                 player.seek(sync_state["current_frame"] / fps)

        if sync_state["playing"]:
            ret, frame = cap.read()
            if not ret:
                break # Video ended
            
            # Host sends sync ping every 2 seconds to keep Client perfectly matched
            if role == "host" and time.time() - last_sync_time > 2.0:
                current_f = int(cap.get(cv2.CAP_PROP_POS_FRAMES))
                sync_state["command_queue"].append(f"SYNC:{current_f}|")
                last_sync_time = time.time()
        else:
            # If paused, keep showing the same frame
            pass 

        # Process Audio
        if play_audio and player and sync_state["playing"]:
            audio_frame, val = player.get_frame()

        # Crop and Split
        cropped = frame[y_start:y_end, 0:orig_w]
        display_frame = cropped[:, 0:half_w] if side == "left" else cropped[:, half_w:orig_w]
        
        # Add UI Buttons
        display_frame = display_frame.copy()
        buttons = draw_buttons(display_frame, role == "host")
        
        cv2.setMouseCallback(window_name, handle_mouse, param={"buttons": buttons, "is_host": role=="host"})
        cv2.imshow(window_name, display_frame)

        if cv2.waitKey(frame_delay) & 0xFF == ord('q'):
            sync_state["exit"] = True
            if role == "host":
                sync_state["command_queue"].append("EXIT|")
            break

    # Cleanup
    cap.release()
    cv2.destroyAllWindows()
    if player:
        player.close_player()


# --- TKINTER LAUNCHER UI ---
