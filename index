import cv2
import sys
import os

def play_half_video(video_path, side="left"):
    # Load the video
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        print(f"Error: Could not open video at {video_path}")
        return

    # Get video FPS to play at normal speed
    fps = cap.get(cv2.CAP_PROP_FPS)
    delay = int(1000 / fps) if fps > 0 else 30

    # Read the first frame to get original dimensions
    ret, frame = cap.read()
    if not ret:
        print("Error: Could not read video frames.")
        return

    orig_h, orig_w = frame.shape[:2]

    # 1. Calculate the 32:9 crop dimensions
    # To convert 16:9 to 32:9, we keep the width and shrink the height
    target_h = int(orig_w * (9 / 32))
    y_start = (orig_h - target_h) // 2
    y_end = y_start + target_h

    # 2. Calculate the split down the middle
    half_w = orig_w // 2

    # Setup the fullscreen window
    window_name = f"Ultrawide Player - {side.capitalize()} Screen"
    cv2.namedWindow(window_name, cv2.WINDOW_NORMAL)
    cv2.setWindowProperty(window_name, cv2.WND_PROP_FULLSCREEN, cv2.WINDOW_FULLSCREEN)

    print(f"Playing {side} half... Press 'q' to quit.")

    while True:
        if not ret:
            # Loop the video or break. Here we just end it.
            break

        # Crop out the center 32:9 strip
        cropped_32_9 = frame[y_start:y_end, 0:orig_w]

        # Split the strip into the Left or Right half
        if side == "left":
            display_frame = cropped_32_9[:, 0:half_w]
        else:
            display_frame = cropped_32_9[:, half_w:orig_w]

        # Show the frame
        cv2.imshow(window_name, display_frame)

        # Wait for the correct frame delay, exit if 'q' is pressed
        if cv2.waitKey(delay) & 0xFF == ord('q'):
            break

        # Read the next frame
        ret, frame = cap.read()

    # Cleanup
    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    print("=== 32:9 Ultrawide Dual-Laptop Player ===")
    
    # Get the video path
    video_file = input("Enter the path to the video file (e.g., video.mp4): ").strip()
    
    # Remove quotes if the user dragged and dropped the file into the terminal
    if video_file.startswith('"') and video_file.endswith('"'):
        video_file = video_file[1:-1]

    if not os.path.exists(video_file):
        print("Error: That file does not exist.")
        sys.exit(1)

    # Ask the user which side this laptop is
    choice = input("Which screen is this laptop? (left / right): ").strip().lower()

    if choice in ["left", "right"]:
        play_half_video(video_file, choice)
    else:
        print("Invalid choice. Please run the script again and type 'left' or 'right'.")
