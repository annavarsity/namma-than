<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pure CSS Split Screen Video</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden; /* Prevents scrolling */
            background-color: black;
            font-family: sans-serif;
        }

        /* The floating control panel */
        .controls {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 10;
            background: rgba(255, 255, 255, 0.9);
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        input {
            padding: 8px;
            margin-right: 5px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        button {
            padding: 8px 12px;
            margin: 5px 2px;
            cursor: pointer;
            border: none;
            background: #28a745;
            color: white;
            border-radius: 4px;
            font-weight: bold;
        }

        button.side-btn {
            background: #007bff;
        }

        button:hover { opacity: 0.8; }

        /* --- THE CSS SPLIT MAGIC --- */

        /* 1. The wrapper strictly limits what you see to 1 screen width */
        .video-wrapper {
            position: relative;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
        }

        /* 2. The video is forced to be 200% wide */
        iframe {
            position: absolute;
            top: 0;
            width: 200vw;
            height: 100vh;
            border: none;
            transition: left 0.4s ease-in-out; /* Smooth sliding animation */
        }

        /* 3. Left side keeps it at coordinate 0 */
        .left-side iframe {
            left: 0;
        }

        /* 4. Right side shifts the whole 200% video left by exactly 1 screen width */
        .right-side iframe {
            left: -100vw;
        }
    </style>
</head>
<body>

    <div class="controls" id="control-panel">
        <input type="text" id="video-id" value="dQw4w9WgXcQ" placeholder="YouTube Video ID">
        <button onclick="loadVideo()">Load Custom Video</button>
        <hr style="border: 0; border-top: 1px solid #ccc; margin: 10px 0;">
        <button class="side-btn" onclick="setScreen('left')">Make this Left Laptop</button>
        <button class="side-btn" onclick="setScreen('right')">Make this Right Laptop</button>
        <button onclick="hideControls()" style="background:#dc3545;">Hide Controls</button>
    </div>

    <div class="video-wrapper left-side" id="wrapper">
        <iframe id="yt-player" src="https://www.youtube.com/embed/dQw4w9WgXcQ" allowfullscreen></iframe>
    </div>

    <script>
        // Changes the CSS class to shift the video left or right
        function setScreen(side) {
            const wrapper = document.getElementById('wrapper');
            if (side === 'left') {
                wrapper.className = 'video-wrapper left-side';
            } else {
                wrapper.className = 'video-wrapper right-side';
            }
        }

        // Loads a new YouTube video based on the ID in the input box
        function loadVideo() {
            const vidId = document.getElementById('video-id').value;
            const player = document.getElementById('yt-player');
            player.src = `https://www.youtube.com/embed/${vidId}`;
        }

        // Hides the white control panel so the screen is completely black/video
        function hideControls() {
            document.getElementById('control-panel').style.display = 'none';
        }
    </script>

</body>
</html>
