import tkinter as tk
from tkinter import filedialog, messagebox
from tkinter import ttk
import subprocess
import threading
import os

def browse_input():
    filename = filedialog.askopenfilename(
        title="Select Input Video",
        filetypes=(("Video files", "*.mp4 *.mkv *.avi *.mov"), ("All files", "*.*"))
    )
    if filename:
        input_var.set(filename)

def browse_output():
    filename = filedialog.asksaveasfilename(
        title="Save Output Video As",
        defaultextension=".mp4",
        filetypes=(("MP4 Video", "*.mp4"), ("All files", "*.*"))
    )
    if filename:
        output_var.set(filename)

def run_ffmpeg(input_file, output_file, position):
    if position == "Left":
        pad_filter = "pad=iw*2:ih:0:0"
    else:
        pad_filter = "pad=iw*2:ih:iw:0"

    command = [
        "ffmpeg",
        "-i", input_file,
        "-vf", pad_filter,
        "-c:a", "copy",
        "-y",
        output_file
    ]

    try:
        # Run FFmpeg without opening a new console window (specifically for Windows)
        startupinfo = None
        if os.name == 'nt':
            startupinfo = subprocess.STARTUPINFO()
            startupinfo.dwFlags |= subprocess.STARTF_USESHOWWINDOW

        subprocess.run(command, check=True, startupinfo=startupinfo)
        
        # Update UI safely from thread
        root.after(0, lambda: messagebox.showinfo("Success", f"Video successfully saved to:\n{output_file}"))
    except subprocess.CalledProcessError as e:
        root.after(0, lambda: messagebox.showerror("Error", f"An error occurred during conversion.\nCheck if FFmpeg is installed."))
    except FileNotFoundError:
        root.after(0, lambda: messagebox.showerror("Error", "FFmpeg not found! Please ensure it is installed and added to your system PATH."))
    finally:
        # Reset UI
        root.after(0, reset_ui)

def start_conversion():
    input_file = input_var.get()
    output_file = output_var.get()
    position = side_var.get()

    if not input_file or not output_file:
        messagebox.showwarning("Missing Files", "Please select both an input and output file.")
        return

    # Disable buttons and show progress text
    convert_btn.config(state=tk.DISABLED)
    status_var.set("Status: Converting... Please wait.")
    
    # Run the conversion in a separate thread so the GUI doesn't freeze
    thread = threading.Thread(target=run_ffmpeg, args=(input_file, output_file, position))
    thread.daemon = True
    thread.start()

def reset_ui():
    convert_btn.config(state=tk.NORMAL)
    status_var.set("Status: Ready")

# --- GUI Setup ---
root = tk.Tk()
root.title("16:9 to 32:9 Video Converter")
root.geometry("500x250")
root.resizable(False, False)

# Variables
input_var = tk.StringVar()
output_var = tk.StringVar()
side_var = tk.StringVar(value="Left")
status_var = tk.StringVar(value="Status: Ready")

# Styling
padding_opts = {'padx': 10, 'pady': 5}

# Input Row
tk.Label(root, text="Input Video:").grid(row=0, column=0, sticky="w", **padding_opts)
tk.Entry(root, textvariable=input_var, width=40, state="readonly").grid(row=0, column=1, **padding_opts)
tk.Button(root, text="Browse", command=browse_input).grid(row=0, column=2, **padding_opts)

# Output Row
tk.Label(root, text="Output Video:").grid(row=1, column=0, sticky="w", **padding_opts)
tk.Entry(root, textvariable=output_var, width=40, state="readonly").grid(row=1, column=1, **padding_opts)
tk.Button(root, text="Browse", command=browse_output).grid(row=1, column=2, **padding_opts)

# Side Selection Row
tk.Label(root, text="Keep Video On:").grid(row=2, column=0, sticky="w", **padding_opts)
side_dropdown = ttk.Combobox(root, textvariable=side_var, values=["Left", "Right"], state="readonly", width=15)
side_dropdown.grid(row=2, column=1, sticky="w", **padding_opts)

# Status Label
tk.Label(root, textvariable=status_var, fg="blue").grid(row=3, column=0, columnspan=3, pady=(15, 5))

# Convert Button
convert_btn = tk.Button(root, text="Convert Video", command=start_conversion, bg="#4CAF50", fg="white", font=("Arial", 10, "bold"), width=15)
convert_btn.grid(row=4, column=0, columnspan=3, pady=10)

root.mainloop()
