    root.title("32:9 Ultrawide Setup")
    root.geometry("400x450")
    root.configure(padx=20, pady=20)

    video_path = tk.StringVar()

    def select_video():
        path = filedialog.askopenfilename(title="Select Video File", filetypes=[("Video Files", "*.mp4 *.mkv *.avi")])
        if path:
            video_path.set(path)

    def launch(role):
        if not video_path.get():
            messagebox.showerror("Error", "Please select a video file first!")
            return
            
        side = side_var.get()
        audio = audio_var.get()
        pin = pin_entry.get().strip()

        if len(pin) != 4 or not pin.isdigit():
            messagebox.showerror("Error", "PIN must be exactly 4 digits.")
            return

        if audio and not FFPYPLAYER_AVAILABLE:
            messagebox.showerror("Error", "ffpyplayer not installed. Cannot play audio.")
            return

        root.destroy()
        start_player(video_path.get(), side, role, pin, audio)

    # UI Elements
    tk.Label(root, text="Step 1: Select Video", font=("Arial", 12, "bold")).pack(anchor="w")
    tk.Button(root, text="Browse...", command=select_video).pack(fill="x", pady=5)
    tk.Label(root, textvariable=video_path, fg="gray", wraplength=350).pack()

    tk.Label(root, text="\nStep 2: Settings", font=("Arial", 12, "bold")).pack(anchor="w")
    
    side_var = tk.StringVar(value="left")
    tk.Radiobutton(root, text="Left Screen", variable=side_var, value="left").pack(anchor="w")
    tk.Radiobutton(root, text="Right Screen", variable=side_var, value="right").pack(anchor="w")

    audio_var = tk.BooleanVar(value=False)
    tk.Checkbutton(root, text="Play Audio on this laptop", variable=audio_var).pack(anchor="w", pady=10)

    tk.Label(root, text="\nStep 3: Network Link", font=("Arial", 12, "bold")).pack(anchor="w")
    
    pin_frame = tk.Frame(root)
    pin_frame.pack(fill="x", pady=5)
    tk.Label(pin_frame, text="4-Digit Sync PIN:").pack(side="left")
    
    # Auto-generate a pin
    random_pin = str(random.randint(1000, 9999))
    pin_entry = tk.Entry(pin_frame, width=10)
    pin_entry.insert(0, random_pin)
    pin_entry.pack(side="left", padx=10)

    btn_frame = tk.Frame(root)
    btn_frame.pack(fill="x", pady=20)
    
    tk.Button(btn_frame, text="START AS HOST", bg="green", fg="white", font=("Arial", 10, "bold"), 
              command=lambda: launch("host")).pack(side="left", expand=True, fill="x", padx=5)
              
    tk.Button(btn_frame, text="JOIN AS CLIENT", bg="blue", fg="white", font=("Arial", 10, "bold"), 
              command=lambda: launch("client")).pack(side="left", expand=True, fill="x", padx=5)

    root.mainloop()

if __name__ == "__main__":
    run_launcher()
