import vlc
import socket
import threading
import time
import json
import os
import sys
import customtkinter as ctk
from tkinter import filedialog

# Network Configuration
UDP_IP = "0.0.0.0"       # Listen on all interfaces
UDP_PORT = 5005          # Port for continuous sync pings
BROADCAST_IP = "<broadcast>"

class VideoSyncApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("32:9 Sync Player")
        self.geometry("800x600")

        # VLC Instance and Player
        # Note: Added --crop argument here. For 32:9 splitting, you will adjust this.
        self.vlc_instance = vlc.Instance('--no-xlib', '--aspect-ratio=16:9')
        self.media_player = self.vlc_instance.media_player_new()

        self.is_host = False
        self.syncing = False
        self.setup_ui()

    def setup_ui(self):
        # Video Display Frame
        self.video_frame = ctk.CTkFrame(self, width=800, height=450)
        self.video_frame.pack(pady=10, padx=10, fill="both", expand=True)

        # Controls Frame
        self.control_frame = ctk.CTkFrame(self)
        self.control_frame.pack(pady=10, fill="x")

        self.btn_host = ctk.CTkButton(self.control_frame, text="Start as Host", command=self.start_host)
        self.btn_host.pack(side="left", padx=10)

        self.btn_client = ctk.CTkButton(self.control_frame, text="Start as Client", command=self.start_client)
        self.btn_client.pack(side="left", padx=10)

        self.btn_play = ctk.CTkButton(self.control_frame, text="Select Video & Play", command=self.load_and_play, state="disabled")
        self.btn_play.pack(side="right", padx=10)

    def attach_vlc_to_gui(self):
        """Binds the VLC output to the Tkinter Frame based on OS."""
        # Get the window ID of the Tkinter frame
        win_id = self.video_frame.winfo_id()

        if sys.platform == "win32":
            self.media_player.set_hwnd(win_id)
        elif sys.platform == "linux":
            self.media_player.set_xwindow(win_id)
        elif sys.platform == "darwin": # macOS
            self.media_player.set_nsobject(win_id)

    def start_host(self):
        self.is_host = True
        self.btn_host.configure(state="disabled")
        self.btn_client.configure(state="disabled")
        self.btn_play.configure(state="normal")
        print("Started as Host. Waiting for video selection...")

    def start_client(self):
        self.is_host = False
        self.btn_host.configure(state="disabled")
        self.btn_client.configure(state="disabled")
        self.btn_play.configure(state="normal")
        print("Started as Client. Ready to sync.")

        # Start listening for host sync data
        threading.Thread(target=self.client_sync_listener, daemon=True).start()

    def load_and_play(self):
        filepath = filedialog.askopenfilename(filetypes=[("Video Files", "*.mp4 *.mkv *.avi")])
        if not filepath:
            return

        self.attach_vlc_to_gui()
        media = self.vlc_instance.media_new(filepath)
        self.media_player.set_media(media)
        self.media_player.play()

        self.syncing = True
        if self.is_host:
            threading.Thread(target=self.host_sync_broadcaster, daemon=True).start()

    def host_sync_broadcaster(self):
        """Host sends its current playback time every 0.5 seconds via UDP."""
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)

        while self.syncing:
            time.sleep(0.5)
            if self.media_player.is_playing():
                current_time = self.media_player.get_time() # Time in milliseconds
                payload = json.dumps({"state": "playing", "time_ms": current_time})
                sock.sendto(payload.encode(), (BROADCAST_IP, UDP_PORT))

    def client_sync_listener(self):
        """Client listens to Host UDP packets and corrects its timeline if needed."""
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.bind((UDP_IP, UDP_PORT))

        while True:
            data, addr = sock.recvfrom(1024)
            if not self.syncing:
                continue

            payload = json.loads(data.decode())
            host_time = payload.get("time_ms", 0)
            client_time = self.media_player.get_time()

            # If client drifts more than 200ms from the host, force a time correction
            if abs(host_time - client_time) > 200:
                print(f"Sync drift detected! Adjusting by {host_time - client_time}ms")
                self.media_player.set_time(host_time)

if __name__ == "__main__":
    app = VideoSyncApp()
    app.mainloop()
